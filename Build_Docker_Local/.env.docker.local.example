NODE_ENV=production
PORT=3000
PAYLOAD_LIMIT=1mb
HOST_PORT=3000

# Em ambiente de imagem unica (frontend servido pelo backend),
# use localhost:3000 como origem permitida.
ALLOWED_ORIGINS=http://localhost:3000

# Banco de dados externo (ja existente)
DB_HOST=host.docker.internal
DB_PORT=5432
DB_NAME=homefinance
DB_USER=homefinance_user
DB_PASS=troque-esta-senha

# JWT
JWT_SECRET=troque-esta-chave-local
JWT_EXPIRES_MIN=30
JWT_MAX_HOURS=24

# Rate limits (local)
AUTH_RATE_LIMIT_MAX=200
AUTH_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX=1000
API_RATE_LIMIT_WINDOW_MS=60000
WRITE_RATE_LIMIT_MAX=300
WRITE_RATE_LIMIT_WINDOW_MS=60000
